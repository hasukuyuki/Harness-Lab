# Harness Lab model configuration
OPENAI_API_KEY=your_provider_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
HARNESS_LAB_MODEL_PROVIDER=deepseek
HARNESS_LAB_MODEL_NAME=deepseek-chat

# Local backend settings
HOST=0.0.0.0
PORT=4600
DEBUG=False

# Remote worker plane baseline
HARNESS_DB_URL=postgresql://harness_lab:harness_lab@localhost:5432/harness_lab
HARNESS_REDIS_URL=redis://localhost:6379/0
HARNESS_WORKER_POLL_INTERVAL=1.0
HARNESS_REDIS_NAMESPACE=harness_lab
HARNESS_SANDBOX_BACKEND=docker
HARNESS_SANDBOX_IMAGE=harness-lab/sandbox:local
HARNESS_SANDBOX_TIMEOUT_SECONDS=20
HARNESS_DOCKER_BIN=docker
