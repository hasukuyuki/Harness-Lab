# Harness Lab model configuration
OPENAI_API_KEY=your_provider_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
HARNESS_LAB_MODEL_PROVIDER=deepseek
HARNESS_LAB_MODEL_NAME=deepseek-chat

# Local backend settings
HOST=0.0.0.0
PORT=4600
DEBUG=False

# Remote worker plane baseline
HARNESS_DB_URL=postgresql://harness_lab:harness_lab@localhost:5432/harness_lab
HARNESS_REDIS_URL=redis://localhost:6379/0
HARNESS_WORKER_POLL_INTERVAL=1.0
HARNESS_REDIS_NAMESPACE=harness_lab

# =============================================================================
# Artifact Storage Backend Configuration
# =============================================================================
# Supported backends: 'local' (filesystem) or 's3' (S3-compatible object storage)
# 
# For local development:
#   - Use 'local' for simple file-based storage
#   - Use 's3' with MinIO for production-like testing
#
# For production deployment:
#   - Use 's3' with AWS S3 or compatible object storage (MinIO, Ceph, etc.)
# =============================================================================

HARNESS_ARTIFACT_BACKEND=local
HARNESS_ARTIFACT_ROOT=backend/data/harness_lab/artifacts

# S3-compatible configuration (used when HARNESS_ARTIFACT_BACKEND=s3)
# For MinIO (default development setup):
#   HARNESS_ARTIFACT_BACKEND=s3
#   HARNESS_AWS_ENDPOINT_URL=http://localhost:9000
#   HARNESS_AWS_ACCESS_KEY_ID=minioadmin
#   HARNESS_AWS_SECRET_ACCESS_KEY=minioadmin
#
# For AWS S3:
#   HARNESS_ARTIFACT_BACKEND=s3
#   HARNESS_AWS_ENDPOINT_URL=  # leave empty for AWS
#   HARNESS_AWS_REGION=us-east-1
#   HARNESS_AWS_ACCESS_KEY_ID=your-access-key
#   HARNESS_AWS_SECRET_ACCESS_KEY=your-secret-key

HARNESS_ARTIFACT_BUCKET=harness-lab-artifacts
HARNESS_ARTIFACT_PREFIX=harness-lab
HARNESS_AWS_ENDPOINT_URL=http://localhost:9000
HARNESS_AWS_REGION=us-east-1
HARNESS_AWS_ACCESS_KEY_ID=minioadmin
HARNESS_AWS_SECRET_ACCESS_KEY=minioadmin

# Sandbox configuration
HARNESS_SANDBOX_BACKEND=docker
HARNESS_SANDBOX_IMAGE=harness-lab/sandbox:local
HARNESS_SANDBOX_TIMEOUT_SECONDS=20
HARNESS_DOCKER_BIN=docker
HARNESS_MICROVM_BINARY=python3
HARNESS_MICROVM_KERNEL_IMAGE=backend/data/harness_lab/microvm/vmlinux.bin
HARNESS_MICROVM_ROOTFS_IMAGE=backend/data/harness_lab/microvm/rootfs.img
HARNESS_MICROVM_WORKDIR=backend/data/harness_lab/microvm/workdir
HARNESS_MICROVM_TIMEOUT_SECONDS=20
HARNESS_MICROVM_ENABLE_SNAPSHOTS=false
